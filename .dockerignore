# Dependencies — reinstalled inside the image
node_modules

# Build output — rebuilt inside the image
.next

# Version control
.git
.gitignore

# Logs
*.log
npm-debug.log*

# Local environment (secrets — never bake into image)
.env.local
.env*.local

# Tests — not needed in production image
__tests__
jest.config.ts
jest.setup.ts
coverage

# Dev tooling
.eslintrc*
.prettierrc*
.editorconfig

# OS artefacts
.DS_Store
Thumbs.db

# Docker files themselves (avoid redundant COPY)
Dockerfile
docker-compose*.yml
.dockerignore
