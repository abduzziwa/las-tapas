# ── Server secrets ──────────────────────────────────────────────────────────
# HMAC key used to sign QR tokens and checkout tokens.
# Must be changed in production. Use: openssl rand -hex 32
QR_SECRET=lastapassecretkeyforencryptionandhmac

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Connection string. In Docker this is the service name: mongodb
MONGODB_URI=mongodb://localhost:27017/
# Database name (default: LAS_TAAPS)
MONGODB_DB=LAS_TAAPS

# ── App public host (used by client-side fetch calls) ────────────────────────
# Set to the hostname:port where the Next.js server is reachable from the browser.
# In Docker on localhost: localhost:3001
# In production: your-domain.com or your-server-ip:3001
NEXT_PUBLIC_APP_HOST=localhost:3001
NEXT_PUBLIC_HOST_ROUTE=http://localhost:3001/
NEXT_PUBLIC_HOME_URL=http://localhost:3001
